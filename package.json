{
  "name": "gateproof",
  "version": "0.1.0",
  "private": true,
  "description": "Hybrid Codex and Claude security assessment skills for KISA compliance and full-stack security reviews.",
  "license": "MIT",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "artifacts:capture": "node ./scripts/capture-report.mjs",
    "reports:generate": "node ./scripts/generate-report.mjs",
    "evals:artifacts": "node ./scripts/run-evals.mjs --score-manifest artifacts/report-manifest.json",
    "evals:captures": "node ./scripts/run-evals.mjs --score-captures artifacts/capture-index.json",
    "evals:run": "node ./scripts/run-evals.mjs",
    "evals:score": "node ./scripts/run-evals.mjs --score-report",
    "skill:install": "node ./scripts/install.mjs",
    "skill:doctor": "node ./scripts/doctor.mjs",
    "skill:validate": "node ./scripts/validate-skills.mjs"
  }
}
